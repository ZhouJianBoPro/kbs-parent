<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kbs.core.mapper.AppUserMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.kbs.core.entity.AppUser">
        <id column="id" property="id"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="create_user" property="createUser"/>
        <result column="update_user" property="updateUser"/>
        <result column="del_flag" property="delFlag"/>
        <result column="account_type" property="accountType"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="nickname" property="nickname"/>
        <result column="phone" property="phone"/>
        <result column="email" property="email"/>
        <result column="status" property="status"/>
        <result column="remark" property="remark"/>
    </resultMap>

    <!-- 用户VO映射结果 -->
    <resultMap id="UserVOMap" type="com.kbs.core.vo.UserVO">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="nickname" property="nickname"/>
        <result column="phone" property="phone"/>
        <result column="email" property="email"/>
        <result column="status" property="status"/>
        <result column="remark" property="remark"/>
        <result column="account_type" property="accountType"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, create_time, update_time, create_user, update_user, del_flag,
        account_type, username, password, nickname, phone, email, status, remark
    </sql>

    <!-- 分页查询用户列表 -->
    <select id="selectUserPage" resultMap="UserVOMap">
        SELECT
            id,
            username,
            nickname,
            phone,
            email,
            status,
            remark,
            account_type,
            create_time
        FROM app_user
        <where>
            del_flag = 0
            AND account_type = 'NORMAL'
            <if test="request.username != null and request.username != ''">
                AND username LIKE CONCAT('%', #{request.username}, '%')
            </if>
            <if test="request.nickname != null and request.nickname != ''">
                AND nickname LIKE CONCAT('%', #{request.nickname}, '%')
            </if>
            <if test="request.phone != null and request.phone != ''">
                AND phone LIKE CONCAT('%', #{request.phone}, '%')
            </if>
            <if test="request.status != null">
                AND status = #{request.status}
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

</mapper>
