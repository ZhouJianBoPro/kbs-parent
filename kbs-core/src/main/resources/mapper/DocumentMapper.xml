<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kbs.core.mapper.DocumentMapper">

    <!-- 查询结果映射 -->
    <resultMap id="DocumentVOMap" type="com.kbs.core.vo.DocumentVO">
        <id column="id" property="id"/>
        <result column="doc_name" property="docName"/>
        <result column="doc_type" property="docType"/>
        <result column="file_size" property="fileSize"/>
        <result column="file_url" property="fileUrl"/>
        <result column="status" property="status"/>
        <result column="upload_time" property="uploadTime"/>
        <result column="process_time" property="processTime"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 分页查询文档列表 -->
    <select id="selectDocumentPage" resultMap="DocumentVOMap">
        SELECT
            id,
            doc_name,
            doc_type,
            file_size,
            file_url,
            status,
            upload_time,
            process_time,
            create_time,
            update_time
        FROM document
        <where>
            del_flag = 0
            <if test="request.docName != null and request.docName != ''">
                AND doc_name LIKE CONCAT('%', #{request.docName}, '%')
            </if>
            <if test="request.docType != null and request.docType != ''">
                AND doc_type = #{request.docType}
            </if>
            <if test="request.status != null">
                AND status = #{request.status}
            </if>
            <if test="request.uploadTimeStart != null">
                AND upload_time &gt;= #{request.uploadTimeStart}
            </if>
            <if test="request.uploadTimeEnd != null">
                AND upload_time &lt; DATE_ADD(#{request.uploadTimeEnd}, INTERVAL 1 DAY)
            </if>
        </where>
        ORDER BY upload_time DESC
    </select>

</mapper>
